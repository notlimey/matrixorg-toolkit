# Matrix homeserver URL
BOT_HOMESERVER=https://matrix.org

# Bot account credentials
BOT_USERNAME=@callbot:matrix.org
BOT_PASSWORD=your-bot-password

# Encryption key for the local E2EE database — generate with: openssl rand -hex 32
# Never change this after first run or the bot will lose its E2EE keys
CALLBOT_PICKLE_KEY=change-me-use-openssl-rand-hex-32

# Path to the SQLite database (default: callbot.db)
# CALLBOT_DB_PATH=callbot.db

# Optional: seed rooms on first run (saved to config.json after that).
# Once config.json exists these are ignored — use !callbot commands instead.
# WATCHED_ROOM_ID=!roomid:matrix.org
# ANNOUNCE_ROOM_ID=!roomid:matrix.org

# Log verbosity: debug | info | warn | error (default: info)
# LOG_LEVEL=info

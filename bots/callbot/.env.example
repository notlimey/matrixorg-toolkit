# ── Required ──────────────────────────────────────────────────────────────────

# Matrix homeserver URL
BOT_HOMESERVER=https://matrix.org

# Bot account credentials
BOT_USERNAME=@callbot:matrix.org
BOT_PASSWORD=your-bot-password

# Encryption key for the local E2EE key store.
# Generate with: openssl rand -hex 32
# NEVER change this after first run — you will lose all E2EE keys.
CALLBOT_PICKLE_KEY=change-me-use-openssl-rand-hex-32

# Public HTTPS URL where widget/index.html is served.
# See README for hosting options (Cloudflare Tunnel, nginx, or external hosting).
WIDGET_URL=https://callbot.example.com

# ── Widget server ─────────────────────────────────────────────────────────────

# Enable the built-in HTTP file server on this port.
# Leave unset if you host widget/index.html externally (GitHub Pages, etc.)
WIDGET_PORT=8080

# ── Cloudflare Tunnel (Option A) ──────────────────────────────────────────────

# Token from Cloudflare Zero Trust → Networks → Tunnels.
# Only needed if you use the cloudflared service in compose.yml.
# CLOUDFLARE_TOKEN=your-tunnel-token-here

# ── Optional ──────────────────────────────────────────────────────────────────

# Seed the watched room on first run.
# Ignored once config.json exists — use !callbot commands instead.
# WATCHED_ROOM_ID=!roomid:matrix.org

# Override paths (defaults shown, already set in Dockerfile for Docker deploys)
# CALLBOT_DB_PATH=callbot.db
# CONFIG_PATH=config.json

# Log verbosity: debug | info | warn | error (default: info)
# LOG_LEVEL=info
